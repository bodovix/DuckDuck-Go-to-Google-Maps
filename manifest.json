{
  "manifest_version": 3,
  "name": "DuckDuckGo to Google Maps",
  "version": "1.0",
  "description": "Redirects DuckDuckGo map searches to Google Maps using the !m bang.",
  "permissions": [
    "webNavigation",
    "tabs"
  ],
  "host_permissions": ["*://*.duckduckgo.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "duckduckgo-to-googlemaps@gwyd.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}